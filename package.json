{
  "name": "fortuneflow",
  "private": true,
  "version": "1.0.0",
  "description": "FortuneFlow desktop wealth dashboard",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "electron:dev": "node scripts/electron-dev.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder",
    "electron:dist:mac": "npm run build && electron-builder --mac",
    "electron:dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.fortuneflow.desktop",
    "productName": "FortuneFlow",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
