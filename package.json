{
  "name": "fortuneflow",
  "private": true,
  "version": "1.1.0",
  "description": "FortuneFlow desktop wealth dashboard",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx --watch server/index.ts\"",
    "dev:web": "vite",
    "dev:server": "tsx --watch server/index.ts",
    "electron:dev": "node scripts/electron-dev.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder",
    "electron:dist:mac": "npm run build && electron-builder --mac",
    "electron:dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "idb-keyval": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "resend": "^6.12.3",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.fortuneflow.desktop",
    "productName": "FortuneFlow",
    "icon": "public/icon.png",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.finance",
      "icon": "public/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
